{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/index.html"
    },
    {
      "source": "/privacy.html",
      "destination": "/index.html"
    },
    {
      "source": "/terms",
      "destination": "/index.html"
    },
    {
      "source": "/terms.html",
      "destination": "/index.html"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
