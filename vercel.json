{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.muesli.works"
        }
      ],
      "destination": "https://muesli.works/:path*",
      "permanent": true
    },
    {
      "source": "/privacy.html",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/terms.html",
      "destination": "/terms",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy/index.html"
    },
    {
      "source": "/terms",
      "destination": "/terms/index.html"
    },
    {
      "source": "/on-device-dictation",
      "destination": "/on-device-dictation/index.html"
    },
    {
      "source": "/mac-dictation-app",
      "destination": "/mac-dictation-app/index.html"
    },
    {
      "source": "/best-dictation-apps-mac",
      "destination": "/best-dictation-apps-mac/index.html"
    },
    {
      "source": "/offline-dictation-mac",
      "destination": "/offline-dictation-mac/index.html"
    },
    {
      "source": "/local-meeting-transcription-mac",
      "destination": "/local-meeting-transcription-mac/index.html"
    },
    {
      "source": "/granola-alternative",
      "destination": "/granola-alternative/index.html"
    },
    {
      "source": "/wispr-flow-alternative",
      "destination": "/wispr-flow-alternative/index.html"
    },
    {
      "source": "/otter-ai-alternative",
      "destination": "/otter-ai-alternative/index.html"
    },
    {
      "source": "/fireflies-ai-alternative",
      "destination": "/fireflies-ai-alternative/index.html"
    },
    {
      "source": "/meeting-notes",
      "destination": "/meeting-notes/index.html"
    },
    {
      "source": "/local-first-ai",
      "destination": "/local-first-ai/index.html"
    },
    {
      "source": "/help",
      "destination": "/help/index.html"
    },
    {
      "source": "/changelog",
      "destination": "/changelog/index.html"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
